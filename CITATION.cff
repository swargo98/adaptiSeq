repository-code: "https://github.com/swargo98/adaptiSeq"
url: "https://github.com/swargo98/adaptiSeq"
license: MIT
version: "0.1.0"
keywords:
  - bioinformatics
  - sequencing
  - SRA
  - ENA
  - GSA
  - download
